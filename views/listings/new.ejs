<% layout("/layouts/boilerplate") %>

<form method="POST" action="/listings" novalidate class="needs-validation">
  <div class="row">
    <div class="col-8 offset-2">
      <!-- <br><br> -->
      <h3>Create a New Listing</h3>
      <div class="mb-3">
        <label for="title" class="form-label">Title</label>
        <input
          name="listing[title]"
          placeholder="enter title"
          type="text"
          class="form-control"
          required
        />
        <div class="valid-feedback">Input accepted</div>
        <div class="invalid-feedback">Please enter a title</div>
      </div>
      <div class="mb-3">
        <label for="description" class="form-label">Description</label>
        <textarea
          name="listing[description]"
          class="form-control"
          required
        ></textarea>
        <div class="invalid-feedback">Please provide a description.</div>
        <div class="valid-feedback">Input accepted</div>
      </div>
      <div class="mb-3">
        <label for="image" class="form-label">Image Link</label>
        <input
          name="listing[image]"
          placeholder="enter image URL/Link"
          type="text"
          class="form-control"
        />
      </div>
      <div class="row">
        <div class="mb-3 col-md-4">
          <label for="price" class="form-label">Price</label>
          <input
            name="listing[price]"
            placeholder="enter price"
            type="text"
            class="form-control"
            required
          />
          <div class="invalid-feedback">
            Please enter a price greater than 0
          </div>
          <div class="valid-feedback">Input accepted</div>
        </div>
        <div class="mb-3 col-md-8">
          <label for="country" class="form-label">Country</label>
          <input
            name="listing[country]"
            placeholder="enter country"
            type="text"
            class="form-control"
            required
          />
          <div class="invalid-feedback">Please select your country.</div>
          <div class="valid-feedback">Input accepted</div>
        </div>
      </div>

      <div class="mb-3">
        <label for="location" class="form-label">Location</label>
        <input
          name="listing[location]"
          placeholder="enter location"
          type="text"
          class="form-control"
          required
        />
        <div class="invalid-feedback">Please enter your location.</div>
        <div class="valid-feedback">Input accepted</div>
      </div>
      <br />
      <br />
      <button class="btn add-btn">Add</button>
      <br /><br />
    </div>
  </div>
</form>
