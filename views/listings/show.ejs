<% layout("/layouts/boilerplate") %>
<div class="row mt-3 listing-card">
  <div class="col-8 offset-3 listing-card">
    <h3><%= listing.title %></h3>
  </div>
  <div class="col-6 offset-3 card show-card listing-card">
    <img
      src="<%=listing.image %>"
      class="card-img-top show-image"
      alt="listing image"
    />
    <div class="card-body">
      <p class="card-text">
        <%= listing.description %><br />
        &#8377;<%= listing.price.toLocaleString("en-IN") %><br />
        <%= listing.location %><br />
        <%= listing.country %>
      </p>
    </div>
  </div>

  <br />
  <div class="btns">
    <a
      href="/listings/<%= listing._id %>/edit"
      class="col-1 offset-3 btn btn-dark edit-btn"
      >Edit</a
    >

    <form method="POST" action="/listings/<%=listing._id%>?_method=DELETE">
      <button class="offset-5 btn btn-dark">Delete</button>
    </form>
  </div>

  <div class="row mt-3">
    <h4>Guest Reviews</h4>
    <form
      action="/listings/<%= listing._id %>/reviews"
      method="POST"
      novalidate
      class="needs-validation"
    >
      <div>
        <label for="rating" class="form-label">Rating</label>
        <input
          type="range"
          min="1"
          max="5"
          id="rating"
          name="review[rating]"
          class="form-range"
        />
      </div>
      <div>
        <label for="comment" class="form-label">Comments</label>
        <textarea
          name="review[comment]"
          id="comment"
          cols="5"
          rows="4"
          class="form-control"
          required
        ></textarea>
        <div class="invalid-feedback">
          Please add a review before submitting
        </div>
      </div>
      <button class="mb-2 mt-2 btn btn-outline-dark">Submit</button>
    </form>
    <hr />

    <p><b>All Reviews</b></p>
    <div class="row">
    <% for (review of listing.reviews) { %>
    <div class="col-5 mb-3 ms-3 card">
      <div class="card-body">
        <h5 class="card-text">Jane Doe</h5>
        <p class="card-text"> <%= review.comment %> </p>
        <p class="card-text"> <%= review.rating %> / 5 star </p>
        <form class="mb-3" method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
          <button class="btn btn-dark">Delete</button>
        </form>
      </div>
    </div>
    <% } %>
  </div>
  
  </div>
</div>
